{
  "name": "mixed-p5-typedecls-demo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "refresh-p5-transparency": "pnpm --dir ../../p5.transparency run build && pnpm --dir ../../p5.transparency pack && pnpm install --force"
  },
  "devDependencies": {
    "typescript": "~6.0.2",
    "vite": "^8.0.10"
  },
  "dependencies": {
    "p5": "^2.2.3",
    "p5.transparency": "file:../../p5.transparency/p5.transparency-0.0.17.tgz"
  }
}
